IF OBJECT_ID('Order_Items', 'U') IS NOT NULL DROP TABLE Order_Items;
IF OBJECT_ID('Orders', 'U') IS NOT NULL DROP TABLE Orders;
IF OBJECT_ID('Specifications', 'U') IS NOT NULL DROP TABLE Specifications;
IF OBJECT_ID('Products', 'U') IS NOT NULL DROP TABLE Products;
IF OBJECT_ID('Materials', 'U') IS NOT NULL DROP TABLE Materials;
IF OBJECT_ID('Customers', 'U') IS NOT NULL DROP TABLE Customers;
GO
CREATE TABLE Materials (
    Material_ID INT IDENTITY(1,1) PRIMARY KEY,
    Material_Name NVARCHAR(255) NOT NULL,
    Cost_Per_Unit DECIMAL(10, 2) NOT NULL
);
CREATE TABLE Products (
    Product_ID INT IDENTITY(1,1) PRIMARY KEY,
    Product_Name NVARCHAR(255) NOT NULL
);
CREATE TABLE Specifications (
    Spec_ID INT IDENTITY(1,1) PRIMARY KEY,
    Product_ID INT NOT NULL FOREIGN KEY REFERENCES Products(Product_ID),
    Material_ID INT NOT NULL FOREIGN KEY REFERENCES Materials(Material_ID),
    Quantity_Required DECIMAL(10, 3) NOT NULL
);
CREATE TABLE Customers (
    Customer_ID_Internal INT IDENTITY(1,1) PRIMARY KEY,
    id NVARCHAR(50) NULL,
    name NVARCHAR(255) NULL,
    inn NVARCHAR(50) NULL,
    addres NVARCHAR(MAX) NULL,
    phone NVARCHAR(50) NULL,
    salesman BIT NULL,
    buyer BIT NULL
);
CREATE TABLE Orders (
    Order_ID INT IDENTITY(1,1) PRIMARY KEY,
    Customer_ID INT NOT NULL FOREIGN KEY REFERENCES Customers(Customer_ID_Internal),
    Order_Date DATE DEFAULT (GETDATE())
);
CREATE TABLE Order_Items (
    Item_ID INT IDENTITY(1,1) PRIMARY KEY,
    Order_ID INT NOT NULL FOREIGN KEY REFERENCES Orders(Order_ID),
    Product_ID INT NOT NULL FOREIGN KEY REFERENCES Products(Product_ID),
    Quantity INT NOT NULL
);
