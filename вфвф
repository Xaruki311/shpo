SELECT 
    O.Order_ID AS [Номер заказа],
    C.name
 AS [Покупатель],
    SUM(OI.Q uantity * MaterialCosts.UnitCost) AS [Полная стоимость заказа]
FROM Orders O
JOIN Customers C ON O.Customer_ID = C.Customer_ID_Internal
JOIN Order_Items OI ON O.Order_ID = OI.Order_ID
JOIN (
    SELECT 
        S.Product_ID, 
        SUM(S.Quantity_Required * M.Cost_Per_Unit) AS UnitCost
    FROM Specifications S
    JOIN Materials M ON S.Material_ID = M.Material_ID
	GROUP BY S.Product_ID
) AS MaterialCosts ON OI.Product_ID = MaterialCosts.Product_ID
GROUP BY O.Order_ID, C.name, O.Order_Date;
